# Mark II Studio — Environment Variables
# Copy this to .env and fill in your values

# ── LLM API Keys ────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
DEEPSEEK_API_KEY=sk-...

# ── E2B Sandbox ─────────────────────────────────
E2B_API_KEY=e2b_...

# ── GitHub OAuth ────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:3000/auth/callback

# ── Database ────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://markii:markii@localhost:5432/markii_studio

# ── Redis ───────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Model Selection ─────────────────────────────
OPENAI_BUILDER_MODEL=gpt-5.4-2026-03-05
DEEPSEEK_BUILDER_MODEL=deepseek-reasoner
CLAUDE_JUDGE_MODEL=claude-sonnet-4-20250514
CLAUDE_INTERVIEWER_MODEL=claude-sonnet-4-20250514
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ── Brand ───────────────────────────────────────
PRODUCT_NAME=Mark II Studio

# ── Optional: Stripe (for Iron Legion) ──────────
STRIPE_SECRET_KEY=sk_test_...
